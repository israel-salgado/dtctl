[
  {
    "objectId": "vu9U3hXa3q0AAAABACdidWlsdGluOmRhdmlzLmFub21hbHktZGV0ZWN0b3JzAA",
    "title": "Aurora cluster CPU utilization",
    "enabled": true,
    "analyzer": "static (\u003e90)",
    "eventType": "PERFORMANCE_EVENT",
    "source": "Clouds",
    "description": "Monitors Aurora cluster CPU utilization to detect performance bottlenecks",
    "value": {
      "analyzer": {
        "input": [
          {
            "key": "alertCondition",
            "value": "ABOVE"
          },
          {
            "key": "threshold",
            "value": "90"
          },
          {
            "key": "slidingWindow",
            "value": "5"
          },
          {
            "key": "violatingSamples",
            "value": "3"
          },
          {
            "key": "dealertingSamples",
            "value": "5"
          },
          {
            "key": "query",
            "value": "timeseries cpu=avg(cloud.aws.rds.CPUUtilization), interval:1m"
          }
        ],
        "name": "dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer"
      },
      "description": "Monitors Aurora cluster CPU utilization to detect performance bottlenecks",
      "enabled": true,
      "eventTemplate": {
